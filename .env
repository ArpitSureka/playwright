# Playwright Codegen Environment Variables

# Enable the LLM enhancer for generated code
PW_USE_LLM_ENHANCER=1

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/DevQuasar/Qwen2.5-Coder-7B-Instruct-GGUF:Q8_0

# Debug mode for LLM
# Uncomment to enable debugging
PW_DEBUG_LLM=1

# Enable only recorder-specific debug logs (less noise)
# DEBUG=pw:recorder:*

# Debug log file - redirected to a text file for better readability
# DEBUG_FILE=~/tmp/playwright-recorder-debug.log

# Add a custom variable to show recorder events in the terminal
PW_SHOW_RECORDER_LOGS=1

# Debug logging for Playwright
# Enable all debug logs for Playwright (very verbose)
# DEBUG=pw:*

# Enable specific debug logs
DEBUG=pw:recorder,pw:protocol,pw:browser,pw:api

# Save debug logs to a file (use absolute path)
DEBUG_FILE=playwright-debug.log